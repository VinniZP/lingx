{
  "name": "@lingx/cli",
  "version": "0.0.0",
  "description": "Lingx CLI tool for translation management",
  "private": true,
  "type": "module",
  "bin": {
    "lingx": "./bin/lingx.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@lingx/config": "workspace:*",
    "@types/babel__core": "^7.20.5",
    "@types/babel__generator": "^7.27.0",
    "@types/babel__traverse": "^7.28.0",
    "@types/inquirer": "^9.0.9",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.0",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "@babel/generator": "^7.29.1",
    "@babel/parser": "^7.29.2",
    "@babel/traverse": "^7.29.0",
    "@babel/types": "^7.29.0",
    "@formatjs/icu-messageformat-parser": "^3.5.3",
    "@inquirer/prompts": "^8.3.2",
    "@lingx/shared": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "chalk": "^5.6.2",
    "chokidar": "^5.0.0",
    "commander": "^14.0.3",
    "conf": "^15.1.0",
    "glob": "^13.0.6",
    "inquirer": "^13.3.2",
    "jiti": "^2.6.1",
    "js-yaml": "^4.1.1",
    "ora": "^9.3.0",
    "zod": "^4.3.6"
  }
}
